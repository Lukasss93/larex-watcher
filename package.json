{
  "name": "@lukasss93/larex-watcher",
  "description": "Laravel Larex Watcher for Vite",
  "homepage": "https://github.com/Lukasss93/larex-watcher#readme",
  "author": "Luca Patera",
  "license": "MIT",
  "version": "1.0.16",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lukasss93/larex-watcher"
  },
  "bugs": {
    "url": "https://github.com/Lukasss93/larex-watcher/issues"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ],
      "vite": [
        "dist/vite.d.ts"
      ]
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepublishOnly": "tsup ./src --external virtual-laravel-translations,vue --format cjs,esm --dts"
  },
  "keywords": [],
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
